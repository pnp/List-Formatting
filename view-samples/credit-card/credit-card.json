{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/view-formatting.schema.json",
  "hideSelection": true,
  "hideColumnHeader": true,
  "rowFormatter": {
    "elmType": "div",
    "style": {
      "width": "400px",
      "height": "240px",
      "border-radius": "14px",
      "padding": "22px",
      "margin": "16px auto",
      "color": "#ffffff",
      "font-family": "Arial, sans-serif",
      "display": "flex",
      "flex-direction": "column",
      "justify-content": "space-between",
      "box-shadow": "0 10px 24px rgba(0,0,0,0.45)",
      "background-color": "=if([$Tier] == 'Black', '#1a1a1a', if([$Tier] == 'Platinum', '#2a3f6e', if([$Tier] == 'Gold', '#b88a2c', if([$Tier] == 'Premium', '#4a168b', '#1a4480'))))",
      "border": "1px solid rgba(255,255,255,0.12)"
    },
    "children": [
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "justify-content": "space-between",
          "align-items": "flex-start"
        },
        "children": [
          {
            "elmType": "span",
            "txtContent": "[$Title]",
            "style": {
              "font-size": "14px",
              "font-weight": "bold",
              "letter-spacing": "2px",
              "text-transform": "uppercase"
            }
          },
          {
            "elmType": "span",
            "txtContent": "[$Tier]",
            "style": {
              "font-size": "10px",
              "font-weight": "bold",
              "letter-spacing": "2px",
              "text-transform": "uppercase",
              "padding": "3px 10px",
              "border-radius": "12px",
              "background-color": "rgba(255,255,255,0.18)",
              "border": "1px solid rgba(255,255,255,0.3)"
            }
          }
        ]
      },
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "align-items": "center"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "width": "44px",
              "height": "34px",
              "border-radius": "5px",
              "background-color": "#d4a637",
              "border": "1px solid rgba(0,0,0,0.25)",
              "margin-right": "10px",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "space-between",
              "padding": "4px"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "height": "1px",
                  "background-color": "rgba(0,0,0,0.35)",
                  "margin-bottom": "3px"
                }
              },
              {
                "elmType": "div",
                "style": {
                  "height": "1px",
                  "background-color": "rgba(0,0,0,0.35)",
                  "margin-bottom": "3px"
                }
              },
              {
                "elmType": "div",
                "style": {
                  "height": "1px",
                  "background-color": "rgba(0,0,0,0.35)",
                  "margin-bottom": "3px"
                }
              },
              {
                "elmType": "div",
                "style": {
                  "height": "1px",
                  "background-color": "rgba(0,0,0,0.35)"
                }
              }
            ]
          },
          {
            "elmType": "span",
            "txtContent": "((( ",
            "style": {
              "font-size": "18px",
              "color": "rgba(255,255,255,0.85)",
              "font-weight": "bold"
            }
          }
        ]
      },
      {
        "elmType": "div",
        "txtContent": "[$CardNumber]",
        "style": {
          "font-family": "Consolas, 'Courier New', monospace",
          "font-size": "22px",
          "letter-spacing": "3px",
          "font-weight": "bold"
        }
      },
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "justify-content": "space-between",
          "align-items": "flex-end"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "display": "flex"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "margin-right": "20px"
                },
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "CARDHOLDER",
                    "style": {
                      "font-size": "8px",
                      "letter-spacing": "2px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$CardHolder]",
                    "style": {
                      "font-family": "Consolas, 'Courier New', monospace",
                      "font-size": "13px",
                      "letter-spacing": "2px",
                      "text-transform": "uppercase",
                      "font-weight": "bold",
                      "margin-top": "2px"
                    }
                  }
                ]
              },
              {
                "elmType": "div",
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "VALID THRU",
                    "style": {
                      "font-size": "8px",
                      "letter-spacing": "2px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$ValidThru]",
                    "style": {
                      "font-family": "Consolas, 'Courier New', monospace",
                      "font-size": "13px",
                      "letter-spacing": "2px",
                      "font-weight": "bold",
                      "margin-top": "2px"
                    }
                  }
                ]
              }
            ]
          },
          {
            "elmType": "span",
            "txtContent": "[$Network]",
            "style": {
              "font-size": "22px",
              "font-weight": "bold",
              "font-style": "italic",
              "letter-spacing": "1px"
            }
          }
        ]
      }
    ]
  }
}

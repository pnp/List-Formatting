{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/view-formatting.schema.json",
  "hideSelection": true,
  "hideColumnHeader": true,
  "rowFormatter": {
    "elmType": "div",
    "style": {
      "display": "flex",
      "flex-direction": "row",
      "background-color": "#c0392b",
      "border": "1px solid #6e1d15",
      "border-radius": "10px",
      "box-shadow": "0 6px 18px rgba(0,0,0,0.3)",
      "margin": "16px auto",
      "max-width": "820px",
      "overflow": "hidden",
      "color": "#ffffff",
      "font-family": "Arial, sans-serif"
    },
    "children": [
      {
        "elmType": "div",
        "style": {
          "flex-grow": "3",
          "padding": "14px 18px",
          "border-right": "2px dashed rgba(255,255,255,0.6)",
          "display": "flex",
          "flex-direction": "column"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "justify-content": "space-between",
              "align-items": "center",
              "border-bottom": "1px solid rgba(255,255,255,0.4)",
              "padding-bottom": "6px",
              "margin-bottom": "8px"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "display": "flex",
                  "align-items": "center"
                },
                "children": [
                  {
                    "elmType": "span",
                    "style": {
                      "font-size": "16px",
                      "margin-right": "8px"
                    },
                    "attributes": {
                      "iconName": "Video"
                    }
                  },
                  {
                    "elmType": "span",
                    "txtContent": "[$Cinema]",
                    "style": {
                      "font-size": "12px",
                      "font-weight": "bold",
                      "letter-spacing": "1px",
                      "text-transform": "uppercase"
                    }
                  }
                ]
              },
              {
                "elmType": "span",
                "txtContent": "[$Format]",
                "style": {
                  "font-size": "11px",
                  "font-weight": "bold",
                  "letter-spacing": "1px",
                  "padding": "2px 8px",
                  "border": "1px solid rgba(255,255,255,0.7)",
                  "border-radius": "3px",
                  "background-color": "rgba(0,0,0,0.18)"
                }
              }
            ]
          },
          {
            "elmType": "div",
            "txtContent": "[$Title]",
            "style": {
              "font-size": "22px",
              "font-weight": "bold",
              "line-height": "24px",
              "margin-bottom": "4px"
            }
          },
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "align-items": "center",
              "font-size": "12px",
              "margin-bottom": "10px"
            },
            "children": [
              {
                "elmType": "span",
                "txtContent": "[$Auditorium]",
                "style": {
                  "margin-right": "10px"
                }
              },
              {
                "elmType": "span",
                "txtContent": "[$Rating]",
                "style": {
                  "font-weight": "bold",
                  "padding": "1px 6px",
                  "border": "1px solid rgba(255,255,255,0.6)",
                  "border-radius": "2px",
                  "margin-right": "10px",
                  "font-size": "11px"
                }
              },
              {
                "elmType": "span",
                "txtContent": "=toString([$Runtime]) + ' min'",
                "style": {
                  "color": "rgba(255,255,255,0.85)"
                }
              }
            ]
          },
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "align-items": "flex-end",
              "border-top": "1px solid rgba(255,255,255,0.4)",
              "padding-top": "8px"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "flex-grow": "1",
                  "margin-right": "14px"
                },
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "DATE",
                    "style": {
                      "font-size": "9px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$ShowDate]",
                    "style": {
                      "font-size": "14px",
                      "font-weight": "bold"
                    }
                  }
                ]
              },
              {
                "elmType": "div",
                "style": {
                  "margin-right": "14px"
                },
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "TIME",
                    "style": {
                      "font-size": "9px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$ShowTime]",
                    "style": {
                      "font-size": "14px",
                      "font-weight": "bold"
                    }
                  }
                ]
              },
              {
                "elmType": "div",
                "style": {
                  "margin-right": "14px",
                  "text-align": "center"
                },
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "ROW",
                    "style": {
                      "font-size": "9px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$Row]",
                    "style": {
                      "font-size": "22px",
                      "font-weight": "bold",
                      "line-height": "22px"
                    }
                  }
                ]
              },
              {
                "elmType": "div",
                "style": {
                  "text-align": "center"
                },
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "SEAT",
                    "style": {
                      "font-size": "9px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$Seat]",
                    "style": {
                      "font-size": "28px",
                      "font-weight": "bold",
                      "line-height": "28px"
                    }
                  }
                ]
              }
            ]
          },
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "justify-content": "space-between",
              "font-size": "9px",
              "color": "rgba(255,255,255,0.75)",
              "border-top": "1px solid rgba(255,255,255,0.25)",
              "padding-top": "6px",
              "margin-top": "10px"
            },
            "children": [
              {
                "elmType": "span",
                "txtContent": "NO REFUNDS OR EXCHANGES"
              },
              {
                "elmType": "span",
                "txtContent": "[$BookingRef]",
                "style": {
                  "font-weight": "bold"
                }
              }
            ]
          }
        ]
      },
      {
        "elmType": "div",
        "style": {
          "flex-grow": "1",
          "min-width": "170px",
          "padding": "14px 12px",
          "background-color": "#8e2820",
          "display": "flex",
          "flex-direction": "column",
          "text-align": "center"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "border-bottom": "1px solid rgba(255,255,255,0.4)",
              "padding-bottom": "6px",
              "margin-bottom": "8px"
            },
            "children": [
              {
                "elmType": "div",
                "txtContent": "ADMIT",
                "style": {
                  "font-size": "11px",
                  "letter-spacing": "3px",
                  "font-weight": "bold"
                }
              },
              {
                "elmType": "div",
                "txtContent": "ONE",
                "style": {
                  "font-size": "22px",
                  "letter-spacing": "2px",
                  "font-weight": "bold",
                  "line-height": "22px"
                }
              }
            ]
          },
          {
            "elmType": "div",
            "txtContent": "[$Title]",
            "style": {
              "font-size": "12px",
              "font-weight": "bold",
              "line-height": "14px",
              "margin-bottom": "6px"
            }
          },
          {
            "elmType": "div",
            "txtContent": "[$Auditorium]",
            "style": {
              "font-size": "10px",
              "color": "rgba(255,255,255,0.85)",
              "margin-bottom": "10px"
            }
          },
          {
            "elmType": "div",
            "style": {
              "display": "flex",
              "justify-content": "space-around",
              "align-items": "flex-end",
              "margin-bottom": "10px"
            },
            "children": [
              {
                "elmType": "div",
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "ROW",
                    "style": {
                      "font-size": "9px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$Row]",
                    "style": {
                      "font-size": "18px",
                      "font-weight": "bold",
                      "line-height": "20px"
                    }
                  }
                ]
              },
              {
                "elmType": "div",
                "children": [
                  {
                    "elmType": "div",
                    "txtContent": "SEAT",
                    "style": {
                      "font-size": "9px",
                      "color": "rgba(255,255,255,0.75)"
                    }
                  },
                  {
                    "elmType": "div",
                    "txtContent": "[$Seat]",
                    "style": {
                      "font-size": "22px",
                      "font-weight": "bold",
                      "line-height": "24px"
                    }
                  }
                ]
              }
            ]
          },
          {
            "elmType": "div",
            "style": {
              "font-size": "10px",
              "font-weight": "bold",
              "margin-bottom": "8px"
            },
            "txtContent": "[$ShowDate]"
          },
          {
            "elmType": "div",
            "style": {
              "font-size": "10px",
              "margin-bottom": "10px",
              "color": "rgba(255,255,255,0.85)"
            },
            "txtContent": "[$ShowTime]"
          },
          {
            "elmType": "div",
            "style": {
              "height": "28px",
              "background-color": "#ffffff",
              "border-radius": "2px",
              "margin-bottom": "4px",
              "display": "flex",
              "align-items": "center",
              "justify-content": "space-between",
              "padding": "0 4px"
            },
            "children": [
              { "elmType": "div", "style": { "width": "2px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "4px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "1px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "3px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "2px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "5px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "1px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "3px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "2px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "4px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "1px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "3px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "2px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "1px", "height": "20px", "background-color": "#000" } },
              { "elmType": "div", "style": { "width": "4px", "height": "20px", "background-color": "#000" } }
            ]
          },
          {
            "elmType": "div",
            "txtContent": "[$TicketNumber]",
            "style": {
              "font-size": "10px",
              "letter-spacing": "1px",
              "color": "rgba(255,255,255,0.9)",
              "margin-bottom": "6px"
            }
          },
          {
            "elmType": "div",
            "style": {
              "border-top": "1px solid rgba(255,255,255,0.4)",
              "padding-top": "4px",
              "font-size": "15px",
              "font-weight": "bold"
            },
            "txtContent": "=if([$Price] > 0, '$' + toString([$Price]), '')"
          }
        ]
      }
    ]
  }
}
